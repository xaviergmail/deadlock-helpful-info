{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/xaviergmail/deadlock-helpful-info/data/counters/schema/v1.json",
  "title": "HeroCounters v1",
  "description": "Counter data for one hero (schema version 1: hero→item counters).",
  "type": "object",
  "required": ["schemaVersion", "hero", "itemCounters"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1,
      "description": "Schema version. Must be 1 for this schema."
    },
    "hero": {
      "type": "string",
      "minLength": 1,
      "description": "Hero slug as used in YAML file names (without 'hero_' prefix, e.g. 'abrams')."
    },
    "itemCounters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["item", "confidence", "reason", "lastReviewedPatch"],
        "additionalProperties": false,
        "properties": {
          "item": {
            "type": "string",
            "minLength": 1,
            "description": "Item class name slug (e.g. 'decay', 'metal_skin')."
          },
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"],
            "description": "Confidence level for this counter recommendation."
          },
          "reason": {
            "type": "string",
            "minLength": 1,
            "description": "Human-readable explanation shown in the UI tooltip."
          },
          "lastReviewedPatch": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
            "description": "ISO date (YYYY-MM-DD) of the last patch review."
          }
        }
      }
    }
  }
}
