{
  "name": "deadlock-helpful-info",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "VITE_BASE=${VITE_BASE:-/deadlock-helpful-info/} vite build",
    "preview": "VITE_BASE=${VITE_BASE:-/deadlock-helpful-info/} vite preview",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:e2e": "playwright test --config=./playwright.config.ts",
    "typecheck": "tsc --noEmit",
    "counters:generate": "node --experimental-strip-types scripts/generate-counters.ts",
    "counters:validate": "node --experimental-strip-types scripts/validate-counter-data.ts",
    "analytics:generate": "node --experimental-strip-types scripts/generate-analytics.ts",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "bundle-size": "node --experimental-strip-types scripts/check-bundle-size.ts",
    "prepare": "git config --local core.hooksPath .git/hooks && simple-git-hooks"
  },
  "dependencies": {
    "@deadlock-api/ui-core": "^1.4.0",
    "@solidjs/router": "^0.15.0",
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@playwright/test": "^1.50.0",
    "@solidjs/testing-library": "^0.8.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^2.1.9",
    "ajv": "^8.20.0",
    "gzip-size": "^7.0.0",
    "jsdom": "^26.0.0",
    "lint-staged": "^15.3.0",
    "playwright": "^1.60.0",
    "simple-git-hooks": "^2.11.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^2.1.0",
    "yaml": "^2.9.0"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css}": ["biome check --write --no-errors-on-unmatched"]
  }
}
